{
  "kind": "collectionType",
  "collectionName": "brands",
  "info": {
    "singularName": "brand",
    "pluralName": "brands",
    "displayName": "Brand",
    "description": "Massage chair brand"
  },
  "options": { "draftAndPublish": false },
  "pluginsOptions": {},
  "attributes": {
    "name": { "type": "string", "required": true },
    "slug": { "type": "uid", "targetField": "name", "required": true },
    "description": { "type": "text" },
    "country_of_origin": { "type": "string" },
    "founded_year": { "type": "integer" },
    "logo": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "website_url": { "type": "string" },
    "chairs": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::chair.chair",
      "mappedBy": "brand"
    }
  }
}
