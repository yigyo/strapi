{
  "kind": "collectionType",
  "collectionName": "articles",
  "info": {
    "singularName": "article",
    "pluralName": "articles",
    "displayName": "Article",
    "description": "Blog and buying guide content"
  },
  "options": { "draftAndPublish": true },
  "pluginsOptions": {},
  "attributes": {
    "title": { "type": "string", "required": true },
    "slug": { "type": "uid", "targetField": "title", "required": true },
    "excerpt": { "type": "text" },
    "body": { "type": "richtext", "required": true },
    "category": {
      "type": "enumeration",
      "enum": ["buying_guide", "comparison", "review", "news", "tips"]
    },
    "featured_image": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "related_chairs": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::chair.chair"
    },
    "seo_title": { "type": "string" },
    "seo_description": { "type": "text" },
    "read_time_minutes": { "type": "integer" }
  }
}
